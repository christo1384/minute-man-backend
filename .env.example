# Copy this file to ".env" and fill in whichever key you have.
# You do NOT need all of them — pick the provider you want as your default.

# v5.1 (optional): daily email digest of overdue / due actions. Leave unset
# and the feature is invisible. Any SMTP provider works.
#MM_SMTP_HOST=
#MM_SMTP_PORT=587
#MM_SMTP_USER=
#MM_SMTP_PASS=
#MM_SMTP_FROM=
#MM_DIGEST_TO=office@example.co.nz
#MM_DIGEST_HOUR=6
#MM_PUBLIC_URL=https://minute-man-api.onrender.com

# v3: where the meetings database lives. Leave UNSET for a local SQLite file
# (./minuteman.db — zero setup, but on Render's free tier it is erased on every
# redeploy/restart). For records that survive everything, paste a free Neon
# Postgres connection string (neon.tech, no card needed):
#   DATABASE_URL=postgresql://user:password@host/dbname
#DATABASE_URL=

# v4 (optional): protect the register. When set, every save/close/archive/
# delete needs this key (the app asks for it once and remembers it on the
# device). Leave unset for the open v3 behaviour.
#MM_API_KEY=

# v6: file attachments (voice memos, photos, PDFs). Files live in any
# S3-compatible object store. Leave these UNSET and the attachment feature is
# invisible — the upload button reports that storage isn't configured instead
# of erroring. See STORAGE-SETUP-FOR-CHRIS.md for the ~10-minute one-time setup.
#
# Recommended: Backblaze B2 — free 10GB, NO credit card, S3-compatible.
#   S3_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com   (use YOUR bucket's region)
#   S3_ACCESS_KEY_ID=<B2 application keyID>
#   S3_SECRET_ACCESS_KEY=<B2 applicationKey>
#   S3_BUCKET_NAME=minute-man-attachments
#   S3_REGION=                (optional — auto-parsed from a B2 endpoint if blank)
#S3_ENDPOINT_URL=
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=
#S3_BUCKET_NAME=minute-man-attachments
#S3_REGION=
#
# Alternatively Cloudflare R2 (needs a card on file) — still supported:
#R2_ACCOUNT_ID=
#R2_ACCESS_KEY_ID=
#R2_SECRET_ACCESS_KEY=
#R2_BUCKET_NAME=minute-man-attachments
#R2_ENDPOINT_URL=
# Optional: max upload size in MB (default 25).
#MM_MAX_ATTACHMENT_MB=25
# Audio voice memos are auto-transcribed when GEMINI_API_KEY (below) is set —
# no extra config. Without a Gemini key the file is still stored, just not
# transcribed.

# Which provider to use when a request doesn't specify one:
#   gemini | anthropic | openai | demo
# "demo"   needs no key and lets you test the whole app offline (keyword matching).
# "gemini" is FREE — get a key at https://aistudio.google.com (no credit card).
DEFAULT_PROVIDER=demo

# Google Gemini — FREE tier, key at https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude — paid (~1-2c/transcript), key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI GPT — paid, key at https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
