# Copy this file to ".env" and fill in whichever key you have.
# You do NOT need both — pick the provider you want as your default.

# Which provider to use when a request doesn't specify one:
#   anthropic | openai | demo
# "demo" needs no key and lets you test the whole app offline.
DEFAULT_PROVIDER=demo

# Anthropic Claude — get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI GPT — get a key at https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
